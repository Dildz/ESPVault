{
  "extends": "./tsconfig.shared.json",
  "compilerOptions": {
    "composite": true,
    "lib": ["ES2023"],
    "types": ["node", "electron"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "noEmit": true
  },
  "include": [
    "src/main/**/*.ts",
    "src/preload/**/*.ts",
    "src/shared/**/*.ts",
    "scripts/**/*.mjs"
  ]
}

