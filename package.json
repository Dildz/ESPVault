{
  "name": "esp-board-vault",
  "version": "0.1.0",
  "description": "A local-first desktop notebook for ESP32 board inventory.",
  "main": "dist-electron/main.js",
  "private": true,
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build": "npm run typecheck && vite build && node scripts/build-electron.mjs",
    "typecheck": "vue-tsc --noEmit -p tsconfig.renderer.json && tsc --noEmit -p tsconfig.electron.json",
    "preview": "vite preview"
  },
  "dependencies": {
    "@mdi/font": "^7.4.47",
    "better-sqlite3": "^12.2.0",
    "pinia": "^3.0.3",
    "vue": "^3.5.18",
    "vuetify": "^3.9.5"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.2.0",
    "@vitejs/plugin-vue": "^6.0.1",
    "electron": "^42.0.1",
    "esbuild": "^0.25.8",
    "typescript": "^5.9.2",
    "vite": "^7.1.0",
    "vue-tsc": "^3.0.5"
  }
}
